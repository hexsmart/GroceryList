@model List<GroceryList.Models.GroceryItem>
@using GroceryList.Helpers
@{
    ViewData["Title"] = "Grocery List";
    var grouped = Model.GroupBy(i => EmojiHelper.GetCategory(i.Name)).OrderBy(g => g.Key).ToList();
}

<h1 class="mb-4">🛒 Grocery List</h1>

<form asp-action="Add" method="post" class="mb-4">
    <div class="input-group">
        <input type="text" name="items" class="form-control" placeholder="Enter items separated by commas (e.g. milk, eggs, bread)" required />
        <button class="btn btn-primary" type="submit">Add Items</button>
    </div>
</form>

@if (Model.Any())
{
    <div class="mb-3 d-flex gap-2">
        <button class="btn btn-success" onclick="selectStaples()">⭐ Add Staples</button>
        <button class="btn btn-outline-danger" onclick="deselectAll()">✖ Clear Selection</button>
        <button class="btn btn-outline-secondary" id="view-toggle-btn" onclick="toggleViewMode()">📋 Flat View</button>
    </div>

    <div id="category-container">
        @foreach (var group in grouped)
        {
            var catId = group.Key.Replace(" ", "-");
            <div class="category-section mb-3" data-category="@group.Key">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="drag-handle text-muted" title="Drag to reorder" style="cursor:grab; font-size:1.1rem">⠿</span>
                    <button type="button" class="btn btn-sm btn-link p-0 text-decoration-none fw-bold fs-5 text-dark"
                            onclick="toggleCollapse('@catId')">
                        <span id="chevron-@catId">▾</span> @group.Key
                        <span class="badge bg-secondary ms-1">@group.Count()</span>
                    </button>
                </div>
                <div id="items-@catId" class="category-items">
                    <ul class="list-group mb-2">
                        @foreach (var item in group)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center grocery-row"
                                style="cursor:pointer"
                                data-id="@item.Id"
                                data-name="@EmojiHelper.GetEmoji(item.Name) @item.Name"
                                data-category="@item.Category"
                                onclick="toggleRow(this)">
                                <div class="d-flex align-items-center gap-2">
                                    <input type="checkbox" class="form-check-input row-checkbox mt-0" onclick="event.stopPropagation(); toggleRow(this.closest('.grocery-row'))" />
                                    <span class="fw-semibold item-name">@EmojiHelper.GetEmoji(item.Name) @item.Name</span>
                                </div>
                                <div class="d-none d-sm-flex align-items-center gap-2">
                                    <form asp-action="UpdateCategory" method="post" class="d-flex align-items-center gap-1 mb-0">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <select name="category" class="form-select form-select-sm" style="width:110px" onclick="event.stopPropagation()" onchange="event.stopPropagation()">
                                            <option value="Staple" selected="@(item.Category == "Staple")">Staple</option>
                                            <option value="Other" selected="@(item.Category == "Other")">Other</option>
                                        </select>
                                        <button class="btn btn-sm btn-outline-secondary" type="submit" onclick="event.stopPropagation()">💾</button>
                                    </form>
                                    <form asp-action="Remove" method="post" class="mb-0" id="remove-@item.Id">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button class="btn btn-sm btn-danger" type="button" onclick="event.stopPropagation(); removeFromCart('@item.Id'); document.getElementById('remove-@item.Id').submit()">🗑️</button>
                                    </form>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>

    <ul class="list-group mb-4" id="flat-container" style="display:none">
        @foreach (var item in Model)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center grocery-row"
                style="cursor:pointer"
                data-id="@item.Id"
                data-name="@EmojiHelper.GetEmoji(item.Name) @item.Name"
                data-category="@item.Category"
                onclick="toggleRow(this)">
                <div class="d-flex align-items-center gap-2">
                    <input type="checkbox" class="form-check-input row-checkbox mt-0" onclick="event.stopPropagation(); toggleRow(this.closest('.grocery-row'))" />
                    <span class="fw-semibold item-name">@EmojiHelper.GetEmoji(item.Name) @item.Name</span>
                </div>
                <div class="d-none d-sm-flex align-items-center gap-2">
                    <form asp-action="UpdateCategory" method="post" class="d-flex align-items-center gap-1 mb-0">
                        <input type="hidden" name="id" value="@item.Id" />
                        <select name="category" class="form-select form-select-sm" style="width:110px" onclick="event.stopPropagation()" onchange="event.stopPropagation()">
                            <option value="Staple" selected="@(item.Category == "Staple")">Staple</option>
                            <option value="Other" selected="@(item.Category == "Other")">Other</option>
                        </select>
                        <button class="btn btn-sm btn-outline-secondary" type="submit" onclick="event.stopPropagation()">💾</button>
                    </form>
                    <form asp-action="Remove" method="post" class="mb-0" id="flat-remove-@item.Id">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-sm btn-danger" type="button" onclick="event.stopPropagation(); removeFromCart('@item.Id'); document.getElementById('flat-remove-@item.Id').submit()">🗑️</button>
                    </form>
                </div>
            </li>
        }
    </ul>
}else
{
    <p class="text-muted">No items yet. Add some above!</p>
}

<style>
    .grocery-row.selected {
        background-color: #d1e7dd;
    }
    .category-items.collapsed {
        display: none;
    }
    .drag-handle:active {
        cursor: grabbing;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.3/Sortable.min.js"></script>
<script>
    const cart = JSON.parse(localStorage.getItem('groceryCart') || '{}');
    const catCollapsed = JSON.parse(localStorage.getItem('catCollapsed') || '{}');
    const catOrder = JSON.parse(localStorage.getItem('catOrder') || '[]');
    let flatMode = localStorage.getItem('flatMode') === 'true';

    function applyViewMode() {
        const grouped = document.getElementById('category-container');
        const flat = document.getElementById('flat-container');
        const btn = document.getElementById('view-toggle-btn');
        if (flatMode) {
            grouped.style.display = 'none';
            flat.style.display = '';
            btn.textContent = '🗂️ Category View';
        } else {
            grouped.style.display = '';
            flat.style.display = 'none';
            btn.textContent = '📋 Flat View';
        }
    }

    function toggleViewMode() {
        flatMode = !flatMode;
        localStorage.setItem('flatMode', flatMode);
        applyViewMode();
    }

    applyViewMode();

    // Restore cart selections
    document.querySelectorAll('.grocery-row').forEach(row => {
        if (cart[row.dataset.id]) {
            row.classList.add('selected');
            row.querySelector('.row-checkbox').checked = true;
        }
    });

    // Restore collapsed state
    document.querySelectorAll('.category-section').forEach(section => {
        const catId = section.dataset.category.replace(/ /g, '-');
        if (catCollapsed[catId]) {
            document.getElementById('items-' + catId).classList.add('collapsed');
            document.getElementById('chevron-' + catId).textContent = '▸';
        }
    });

    // Restore category order
    if (catOrder.length) {
        const container = document.getElementById('category-container');
        catOrder.forEach(cat => {
            const el = container.querySelector(`.category-section[data-category="${cat}"]`);
            if (el) container.appendChild(el);
        });
    }

    // Enable drag-to-reorder
    Sortable.create(document.getElementById('category-container'), {
        handle: '.drag-handle',
        animation: 150,
        onEnd: () => {
            const order = [...document.querySelectorAll('.category-section')].map(s => s.dataset.category);
            localStorage.setItem('catOrder', JSON.stringify(order));
        }
    });

    function toggleCollapse(catId) {
        const items = document.getElementById('items-' + catId);
        const chevron = document.getElementById('chevron-' + catId);
        const isCollapsed = items.classList.toggle('collapsed');
        chevron.textContent = isCollapsed ? '▸' : '▾';
        catCollapsed[catId] = isCollapsed;
        localStorage.setItem('catCollapsed', JSON.stringify(catCollapsed));
    }

    function toggleRow(row) {
        const checkbox = row.querySelector('.row-checkbox');
        const isSelected = row.classList.toggle('selected');
        checkbox.checked = isSelected;
        const id = row.dataset.id;
        const name = row.dataset.name;
        if (isSelected) {
            cart[id] = name;
        } else {
            delete cart[id];
        }
        localStorage.setItem('groceryCart', JSON.stringify(cart));
    }

    function removeFromCart(id) {
        const cart = JSON.parse(localStorage.getItem('groceryCart') || '{}');
        delete cart[id];
        localStorage.setItem('groceryCart', JSON.stringify(cart));
    }

    function deselectAll() {
        document.querySelectorAll('.grocery-row.selected').forEach(row => toggleRow(row));
    }

    function selectStaples() {
        document.querySelectorAll('.grocery-row').forEach(row => {
            if (row.dataset.category.toLowerCase() === 'staple' && !row.classList.contains('selected')) {
                toggleRow(row);
            }
        });
    }
</script>

