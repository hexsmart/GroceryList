@model List<GroceryList.Models.GroceryItem>
@using GroceryList.Helpers
@{
    ViewData["Title"] = "Grocery List";
}

<h1 class="mb-4">🛒 Grocery List</h1>

<form asp-action="Add" method="post" class="mb-4">
    <div class="input-group">
        <input type="text" name="items" class="form-control" placeholder="Enter items separated by commas (e.g. milk, eggs, bread)" required />
        <button class="btn btn-primary" type="submit">Add Items</button>
    </div>
</form>

@if (Model.Any())
{
    <div class="mb-3">
        <button class="btn btn-success" onclick="selectStaples()">⭐ Add Staples</button>
    </div>
    <ul class="list-group mb-4">
        @foreach (var item in Model)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center grocery-row"
                style="cursor:pointer"
                data-id="@item.Id"
                data-name="@EmojiHelper.GetEmoji(item.Name) @item.Name"
                data-category="@item.Category"
                onclick="toggleRow(this)">
                <div class="d-flex align-items-center gap-2">
                    <input type="checkbox" class="form-check-input row-checkbox mt-0" onclick="event.stopPropagation(); toggleRow(this.closest('.grocery-row'))" />
                    <span class="fw-semibold item-name">@EmojiHelper.GetEmoji(item.Name) @item.Name</span>
                </div>
                <div class="d-none d-sm-flex align-items-center gap-2">
                    <form asp-action="UpdateCategory" method="post" class="d-flex align-items-center gap-1 mb-0">
                        <input type="hidden" name="id" value="@item.Id" />
                        <select name="category" class="form-select form-select-sm" style="width:110px" onclick="event.stopPropagation()" onchange="event.stopPropagation()">
                            <option value="Staple" selected="@(item.Category == "Staple")">Staple</option>
                            <option value="Other" selected="@(item.Category == "Other")">Other</option>
                        </select>
                        <button class="btn btn-sm btn-outline-secondary" type="submit" onclick="event.stopPropagation()">💾</button>
                    </form>
                    <form asp-action="Remove" method="post" class="mb-0" id="remove-@item.Id">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-sm btn-danger" type="button" onclick="event.stopPropagation(); removeFromCart('@item.Id'); document.getElementById('remove-@item.Id').submit()">🗑️</button>
                    </form>
                </div>
            </li>
        }
    </ul>
}
else
{
    <p class="text-muted">No items yet. Add some above!</p>
}

<style>
    .grocery-row.selected {
        background-color: #d1e7dd;
    }
    .grocery-row.selected .item-name {
        text-decoration: line-through;
        color: #6c757d;
    }
</style>

<script>
    const cart = JSON.parse(localStorage.getItem('groceryCart') || '{}');

    // Restore selections on page load
    document.querySelectorAll('.grocery-row').forEach(row => {
        if (cart[row.dataset.id]) {
            row.classList.add('selected');
            row.querySelector('.row-checkbox').checked = true;
        }
    });

    function toggleRow(row) {
        const checkbox = row.querySelector('.row-checkbox');
        const isSelected = row.classList.toggle('selected');
        checkbox.checked = isSelected;
        const id = row.dataset.id;
        const name = row.dataset.name;
        if (isSelected) {
            cart[id] = name;
        } else {
            delete cart[id];
        }
        localStorage.setItem('groceryCart', JSON.stringify(cart));
    }
    function removeFromCart(id) {
        const cart = JSON.parse(localStorage.getItem('groceryCart') || '{}');
        delete cart[id];
        localStorage.setItem('groceryCart', JSON.stringify(cart));
    }

    function selectStaples() {
        document.querySelectorAll('.grocery-row').forEach(row => {
            if (row.dataset.category.toLowerCase() === 'staple' && !row.classList.contains('selected')) {
                toggleRow(row);
            }
        });
    }
</script>

