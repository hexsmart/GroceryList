@model List<GroceryList.Models.GroceryItem>
@using GroceryList.Helpers
@{
    ViewData["Title"] = "Grocery List";
}

<h1 class="mb-4">🛒 Grocery List</h1>

<form asp-action="Add" method="post" class="mb-4">
    <div class="input-group">
        <input type="text" name="items" class="form-control" placeholder="Enter items separated by commas (e.g. milk, eggs, bread)" required />
        <button class="btn btn-primary" type="submit">Add Items</button>
    </div>
</form>

@if (Model.Any())
{
    <ul class="list-group mb-3">
        @foreach (var item in Model)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span class="fw-semibold">@EmojiHelper.GetEmoji(item.Name) @item.Name</span>
                <div class="d-flex align-items-center gap-2">
                    <form asp-action="UpdateCategory" method="post" class="d-flex align-items-center gap-1 mb-0">
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="text" name="category" value="@item.Category" class="form-control form-control-sm" style="width:140px" placeholder="Category" />
                        <button class="btn btn-sm btn-outline-secondary" type="submit">Save</button>
                    </form>
                    <form asp-action="Remove" method="post" class="mb-0">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-sm btn-danger" type="submit">Remove</button>
                    </form>
                </div>
            </li>
        }
    </ul>

    <form asp-action="Clear" method="post">
        <button class="btn btn-warning" type="submit" onclick="return confirm('Clear all items?')">Clear All</button>
    </form>
}
else
{
    <p class="text-muted">No items yet. Add some above!</p>
}
