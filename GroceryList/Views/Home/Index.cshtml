@model List<GroceryList.Models.GroceryItem>
@using GroceryList.Helpers
@{
    ViewData["Title"] = "Grocery List";
}

<h1 class="mb-4">🛒 Grocery List</h1>

<form asp-action="Add" method="post" class="mb-4">
    <div class="input-group">
        <input type="text" name="items" class="form-control" placeholder="Enter items separated by commas (e.g. milk, eggs, bread)" required />
        <button class="btn btn-primary" type="submit">Add Items</button>
    </div>
</form>

@if (Model.Any())
{
    <ul class="list-group mb-4">
        @foreach (var item in Model)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center grocery-row"
                style="cursor:pointer"
                data-id="@item.Id"
                data-name="@EmojiHelper.GetEmoji(item.Name) @item.Name"
                onclick="toggleRow(this)">
                <div class="d-flex align-items-center gap-2">
                    <input type="checkbox" class="form-check-input row-checkbox mt-0" onclick="event.stopPropagation(); toggleRow(this.closest('.grocery-row'))" />
                    <span class="fw-semibold item-name">@EmojiHelper.GetEmoji(item.Name) @item.Name</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <form asp-action="UpdateCategory" method="post" class="d-flex align-items-center gap-1 mb-0">
                        <input type="hidden" name="id" value="@item.Id" />
                        <input type="text" name="category" value="@item.Category" class="form-control form-control-sm" style="width:140px" placeholder="Category" onclick="event.stopPropagation()" />
                        <button class="btn btn-sm btn-outline-secondary" type="submit" onclick="event.stopPropagation()">Save</button>
                    </form>
                    <form asp-action="Remove" method="post" class="mb-0">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-sm btn-danger" type="submit" onclick="event.stopPropagation()">Remove</button>
                    </form>
                </div>
            </li>
        }
    </ul>

    <div id="selected-section" style="display:none">
        <h4 class="mb-2">🧺 In My Cart</h4>
        <ul class="list-group" id="selected-list"></ul>
    </div>
}
else
{
    <p class="text-muted">No items yet. Add some above!</p>
}

<style>
    .grocery-row.selected {
        background-color: #d1e7dd;
    }
    .grocery-row.selected .item-name {
        text-decoration: line-through;
        color: #6c757d;
    }
</style>

<script>
    function toggleRow(row) {
        const checkbox = row.querySelector('.row-checkbox');
        const isSelected = row.classList.toggle('selected');
        checkbox.checked = isSelected;

        const id = row.dataset.id;
        const name = row.dataset.name;

        if (isSelected) {
            addToCart(id, name);
        } else {
            removeFromCart(id);
        }
    }

    function addToCart(id, name) {
        const list = document.getElementById('selected-list');
        const li = document.createElement('li');
        li.className = 'list-group-item d-flex justify-content-between align-items-center';
        li.id = 'cart-' + id;
        li.innerHTML = `<span class="fw-semibold">${name}</span>
            <button class="btn btn-sm btn-danger" onclick="deselectItem('${id}')">Remove</button>`;
        list.appendChild(li);
        document.getElementById('selected-section').style.display = 'block';
    }

    function removeFromCart(id) {
        const li = document.getElementById('cart-' + id);
        if (li) li.remove();
        if (document.getElementById('selected-list').children.length === 0) {
            document.getElementById('selected-section').style.display = 'none';
        }
    }

    function deselectItem(id) {
        const row = document.querySelector(`.grocery-row[data-id="${id}"]`);
        if (row) {
            row.classList.remove('selected');
            row.querySelector('.row-checkbox').checked = false;
        }
        removeFromCart(id);
    }
</script>

