@{
    ViewData["Title"] = "Shop";
}

<style>
    .list-group-item.selected {
        background-color: #dee2e6;
        color: #6c757d;
    }
</style>

<h1 class="mb-4">🧺 In My Cart</h1>

<div id="empty-msg" class="text-muted" style="display:none">No items in your cart. Go select some from the <a href="/">Grocery List</a>!</div>

<ul class="list-group mb-3" id="cart-list"></ul>

<button id="clear-all-btn" class="btn btn-warning" onclick="clearAll()" style="display:none">🗑️ Clear All</button>

<script>
    const cart = JSON.parse(localStorage.getItem('groceryCart') || '{}');
    const list = document.getElementById('cart-list');
    const emptyMsg = document.getElementById('empty-msg');
    const clearAllBtn = document.getElementById('clear-all-btn');
    const selected = JSON.parse(localStorage.getItem('shopSelected') || '[]');

    if (Object.keys(cart).length === 0) {
        emptyMsg.style.display = 'block';
    } else {
        Object.entries(cart).forEach(([id, name]) => addCartItem(id, name));
        clearAllBtn.style.display = 'inline-block';
    }

    function addCartItem(id, name) {
        const li = document.createElement('li');
        li.className = 'list-group-item d-flex justify-content-between align-items-center';
        li.id = 'cart-' + id;
        if (selected.includes(id)) li.classList.add('selected');
        li.innerHTML = `<span class="fw-semibold">${name}</span>
            <button class="btn btn-sm btn-danger" onclick="removeItem('${id}')">🗑️</button>`;
        li.style.cursor = 'pointer';
        li.addEventListener('click', function(e) {
            if (e.target.tagName !== 'BUTTON') {
                this.classList.toggle('selected');
                const sel = JSON.parse(localStorage.getItem('shopSelected') || '[]');
                const idx = sel.indexOf(id);
                if (this.classList.contains('selected')) { if (idx === -1) sel.push(id); }
                else { if (idx > -1) sel.splice(idx, 1); }
                localStorage.setItem('shopSelected', JSON.stringify(sel));
            }
        });
        list.appendChild(li);
    }

    function removeItem(id) {
        const cart = JSON.parse(localStorage.getItem('groceryCart') || '{}');
        delete cart[id];
        localStorage.setItem('groceryCart', JSON.stringify(cart));
        const sel = JSON.parse(localStorage.getItem('shopSelected') || '[]');
        const idx = sel.indexOf(id);
        if (idx > -1) { sel.splice(idx, 1); localStorage.setItem('shopSelected', JSON.stringify(sel)); }
        const li = document.getElementById('cart-' + id);
        if (li) li.remove();
        if (list.children.length === 0) {
            emptyMsg.style.display = 'block';
            clearAllBtn.style.display = 'none';
        }
    }

    function clearAll() {
        localStorage.removeItem('groceryCart');
        localStorage.removeItem('shopSelected');
        list.innerHTML = '';
        emptyMsg.style.display = 'block';
        clearAllBtn.style.display = 'none';
    }
</script>
