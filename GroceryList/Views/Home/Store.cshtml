@model GroceryList.Models.StoreViewModel
@using GroceryList.Helpers
@{
    ViewData["Title"] = "Store";
}

<h1 class="mb-4">🏪 Store</h1>

<ul class="list-group mb-3">
    @foreach (var item in Model.StoreItems)
    {
        var already = Model.ExistingItems.Contains(item);
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <span class="fw-semibold">@EmojiHelper.GetEmoji(item) @item</span>
            @if (already)
            {
                <span class="badge bg-success">✅ Added</span>
            }
            else
            {
                <form asp-action="Add" method="post" class="mb-0">
                    <input type="hidden" name="items" value="@item" />
                    <button class="btn btn-sm btn-primary" type="submit">➕ Add</button>
                </form>
            }
        </li>
    }
</ul>
